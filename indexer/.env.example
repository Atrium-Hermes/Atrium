# ─────────── Required ───────────
# AtriumRegistry contract address on the target chain
ATRIUM_REGISTRY=0x0000000000000000000000000000000000000000
# Base RPC endpoint (Sepolia or mainnet)
BASE_RPC_URL=https://sepolia.base.org

# ─────────── Optional ───────────
# Block the registry was deployed at. Defaults to 0 (slow first sync).
REGISTRY_DEPLOY_BLOCK=0
# SQLite file path
DATABASE_PATH=./atrium-index.db
# HTTP API port
PORT=3001
# pino log level: trace|debug|info|warn|error
LOG_LEVEL=info
# IPFS gateway base (skill bodies are lazily fetched + cached). Comma-separate for fallbacks.
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs,https://ipfs.io/ipfs,https://dweb.link/ipfs
# How often to poll for new blocks (ms)
INDEX_POLL_INTERVAL_MS=12000
# Max blocks per getLogs window during backfill. Public Base RPCs cap this at
# 2000 (sepolia.base.org rejects wider windows). Raise only on a permissive RPC.
MAX_BLOCK_RANGE=1900
# Concurrent IPFS fetches (keep low to respect gateway rate limits)
IPFS_CONCURRENCY=4
