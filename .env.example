# ─── Deployer / contract operations ───────────────────────────
# Private key for deploying AtriumRegistry. NEVER commit the real value.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Treasury address that receives protocol fees (defaults to deployer if unset)
ATRIUM_TREASURY=

# ─── RPC endpoints ────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ─── Contract verification ────────────────────────────────────
# https://basescan.org/myapikey
BASESCAN_API_KEY=

# ─── Reminder ─────────────────────────────────────────────────
# User-facing config lives at ~/.atrium/.env (created by `atrium init`).
# This file is for the deployer / contract development only.
